[Unit]
Description=Zalman Alpha 2 display
After=graphical-session.target

[Service]
Type=simple
# из исходников:
#   WorkingDirectory=/путь/к/zalman-display
#   ExecStart=/usr/bin/python3 -m zalman_lcd run --quiet
# при установке через pip (даёт команду zalman-display):
ExecStart=%h/.local/bin/zalman-display run --quiet
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
